# ─── Database ───
DATABASE_URL=postgresql://apex:apex_dev_password@localhost:5432/apex_dev
REDIS_URL=redis://localhost:6379

# ─── DigitalOcean Spaces (S3-compatible object storage) ───
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_VIDEOS_BUCKET=apex-videos
DO_SPACES_UPLOADS_BUCKET=apex-uploads
DO_SPACES_ASSETS_BUCKET=apex-assets
DO_CDN_ENDPOINT=https://apex-videos.nyc3.cdn.digitaloceanspaces.com

# ─── JWT ───
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_ULTRA_PRICE_ID=

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Email (SMTP — Resend / SendGrid) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@apex.tv

# ─── YouTube ───
YOUTUBE_API_KEY=

# ─── Runtime ───
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001

# ─── Web (Next.js public) ───
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_CLOUDFRONT_URL=https://cdn.apex.tv
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Deployment (GitHub Actions → DigitalOcean droplets) ───
DO_API_DROPLET_IP=
DO_STREAMING_DROPLET_IP=
DEPLOY_SSH_KEY=
