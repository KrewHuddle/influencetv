# ─── Database ───
DATABASE_URL=postgresql://apex:apex_dev_password@localhost:5432/apex_dev
REDIS_URL=redis://localhost:6379

# ─── AWS ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_VIDEOS_BUCKET=apex-videos
S3_UPLOADS_BUCKET=apex-uploads
S3_ASSETS_BUCKET=apex-assets
CLOUDFRONT_DOMAIN=cdn.apex.tv

# ─── JWT ───
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_ULTRA_PRICE_ID=

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Email (SES) ───
SES_FROM_ADDRESS=noreply@apex.tv

# ─── YouTube ───
YOUTUBE_API_KEY=

# ─── Runtime ───
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001

# ─── Web (Next.js public) ───
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_CLOUDFRONT_URL=https://cdn.apex.tv
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
